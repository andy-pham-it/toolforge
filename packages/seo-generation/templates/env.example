# =====================================
# Toolforge SEO Generation — Env Variables
# =====================================
# Copy this file to .env in your project root and fill in values.

# --- LLM Provider (required for content generation) ---
# Pick one provider — these are shared with @toolforge/core

# Groq (default)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OR Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# OR OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Platform API Keys (optional — REST API path) ---
# Missing keys = fall back to Puppeteer browser automation

# YouTube Data API
YOUTUBE_API_KEY=

# WordPress
WORDPRESS_URL=
WORDPRESS_APP_USER=
WORDPRESS_APP_PASS=

# Facebook Graph API
FACEBOOK_ACCESS_TOKEN=
