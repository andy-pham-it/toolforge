# =====================================
# Toolforge — Environment Variables
# =====================================
# Copy this file to .env in your project root and fill in values.

# --- LLM Provider (pick one) ---

# Groq (default, 14,400 RPD free tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OR Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# OR OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Puppeteer / Browser ---

# Optional: custom Chrome path (default: system Chrome)
# CHROME_PATH=/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome

# --- Server ---

# Port for web UI (default: 3456)
# PORT=3456
